# Copie ce fichier en .env A LA RACINE DU REPO (cp tools/.env.example .env) et remplis les secrets.
# .env est gitignore : il ne part JAMAIS sur GitHub. Les scripts le chargent automatiquement en local.

# === VOIE PRINCIPALE : API mail HTTPS (infomaniak_draft_api.py, marche depuis le web) ===
# Jeton API Infomaniak avec scope "mail" -> manager.infomaniak.com (Developpeur / Jetons API).
INFOMANIAK_API_TOKEN=ton-jeton-api-ici
# Boite source (sert a retrouver le mailboxUuid). Deja le defaut du script.
# INFOMANIAK_MAIL_ADDRESS=thomas.puglisi@kumo-seo.ch
# INFOMANIAK_MAILBOX_UUID=     # force l'uuid si la resolution auto echoue
# INFOMANIAK_MAIL_API=https://mail.infomaniak.com

# === REPLI : IMAP (infomaniak_draft.py, hors cloud uniquement, 993 bloque en cloud) ===
# Mot de passe de la boite Infomaniak (idealement un "mot de passe d'application")
INFOMANIAK_IMAP_PASSWORD=ton-mot-de-passe-ici

# Login = adresse complete. Deja la valeur par defaut du script, decommente pour surcharger.
# INFOMANIAK_IMAP_USER=thomas.puglisi@kumo-seo.ch

# From affiche dans le brouillon (defaut: l'adresse ci-dessus, sans nom).
# INFOMANIAK_FROM=Thomas Puglisi <thomas.puglisi@kumo-seo.ch>

# Serveur / port (defauts Infomaniak, a ne changer que si besoin).
# INFOMANIAK_IMAP_HOST=mail.infomaniak.com
# INFOMANIAK_IMAP_PORT=993

# Force le nom du dossier Brouillons si l'auto-detection se trompe (voir --list-folders).
# INFOMANIAK_DRAFTS_FOLDER=Drafts
